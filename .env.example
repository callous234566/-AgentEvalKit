# 模型 API 配置（SiliconFlow）
# 请前往 https://cloud.siliconflow.cn/ 获取 API 密钥
LLM_API_KEY=sk-your-api-key-here

# Qwen2.5 模型配置
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2400

# 向量数据库配置
CHROMA_DB_PATH=./chroma_db

# 文本分块配置
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# 检索配置
RETRIEVER_TOP_K=3
RETRIEVER_MIN_SCORE=0.35
RETRIEVER_INITIAL_K_MULTIPLIER=6
RETRIEVER_INITIAL_K_MIN=20
RETRIEVER_RERANK_K_MULTIPLIER=4
HYBRID_VECTOR_WEIGHT=0.65
HYBRID_BM25_WEIGHT=0.35
RERANK_VECTOR_WEIGHT=0.65
RERANK_KEYWORD_WEIGHT=0.25
RERANK_PHRASE_WEIGHT=0.10
KEYWORD_HEADER_WEIGHT=0.35
KEYWORD_PHRASE_WEIGHT=0.50
KEYWORD_MAX_CANDIDATE_SCORE=2.5
KEYWORD_PSEUDO_DISTANCE_FLOOR=0.15
KEYWORD_PSEUDO_DISTANCE_MAX_SCORE=0.85
ENABLE_QUERY_REWRITE=true
ENABLE_QUERY_REWRITE_FALLBACK=true
ENABLE_CONTEXTUAL_COMPRESSION=true

# BGE reranker 上下文压缩配置
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_API_BASE=https://api.siliconflow.cn/v1
RERANKER_TIMEOUT=45
RERANKER_MIN_SCORE=0.0
CONTEXTUAL_COMPRESSION_SENTENCES_PER_DOC=3
CONTEXTUAL_COMPRESSION_MAX_CHARS=1800
ENABLE_CONTEXTUAL_COMPRESSION_PROTECTION=true
CONTEXTUAL_COMPRESSION_PROTECT_TOP_N=1
CONTEXTUAL_COMPRESSION_PROTECT_MIN_SCORE=0.7

# 多模态文档解析配置
ENABLE_MULTIMODAL_PARSING=true
MULTIMODAL_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
MULTIMODAL_API_BASE=https://api.siliconflow.cn/v1
MULTIMODAL_MAX_IMAGES_PER_FILE=12
MULTIMODAL_IMAGE_MAX_SIDE=1280
MULTIMODAL_IMAGE_MIN_BYTES=1024
MULTIMODAL_TIMEOUT=90

# 多轮对话配置
CHAT_HISTORY_TURNS=5

# FastAPI 服务配置
API_HOST=127.0.0.1
API_PORT=8000
CORS_ALLOW_ORIGINS=http://127.0.0.1:8501,http://localhost:8501
# 可选。为空时不启用访问保护；配置后非公开接口需携带 Authorization: Bearer <token>
API_TOKEN=

# 网页搜索配置（Tavily Search API，免费 1000次/月）
# 请前往 https://app.tavily.com/ 获取 API 密钥
# 未配置时自动降级使用 DuckDuckGo
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT=15

# Agent 配置
AGENT_ENABLED=true
AGENT_DEBUG=true
AGENT_MAX_ITERATIONS=5
AGENT_MAX_TOOL_CALLS=4
AGENT_MAX_WEB_SEARCHES=1
AGENT_MAX_CODE_EXECUTIONS=1
TOOL_RETRY_MAX_ATTEMPTS=2
TOOL_RETRY_BACKOFF_SECONDS=0.5

# 日志配置
LOG_DIR=./logs
LOG_FILE=app.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
